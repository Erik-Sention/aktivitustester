rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Coach avatars — only the signed-in coach can write their own avatar
    match /coach_avatars/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Athlete files — uploaded directly from client (upload-result-dialog)
    match /athletes/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
