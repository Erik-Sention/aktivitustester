rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // athletes + tests: reads are client-side (Firebase Auth required).
    // Writes go via Next.js server actions (client SDK, no Firebase Auth on server)
    // — protected by HMAC session at the application layer.
    match /athletes/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /tests/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // coach_profiles + athlete_files: client-side only — require Firebase Auth.
    match /coach_profiles/{docId} {
      allow read, write: if request.auth != null;
    }
    match /athlete_files/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
