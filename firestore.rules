rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // athletes + tests: reads are client-side (Firebase Auth required).
    // Writes go via Next.js server actions (client SDK, no Firebase Auth on server)
    // — protected by HMAC session at the application layer.
    match /athletes/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /tests/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // coach_profiles: read is public (display names only, used by server actions too).
    // Write requires Firebase Auth.
    match /coach_profiles/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /athlete_files/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // consent_events: written by server actions (same pattern as athletes/tests).
    match /consent_events/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // declined_athletes: written by server actions when consent is declined.
    match /declined_athletes/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // coaches: read is public (checked at login before auth exists).
    // Write is admin-only (via Firebase Console / Admin SDK).
    match /coaches/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // users: role storage (replaces Firebase Custom Claims for POC).
    // Any authenticated user can read. Write allowed by owner or by an ADMIN.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'
      );
    }
  }
}
